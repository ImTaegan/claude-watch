{
  "hooks": {
    "Notification": [
      { "hooks": [ { "type": "command", "command": "python3 \"__EMIT_PATH__\" needs_input 2>/dev/null || true" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "python3 \"__EMIT_PATH__\" done 2>/dev/null || true" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "python3 \"__EMIT_PATH__\" running 2>/dev/null || true" } ] }
    ],
    "PreToolUse": [
      { "matcher": "*", "hooks": [ { "type": "command", "command": "python3 \"__EMIT_PATH__\" running 2>/dev/null || true" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "python3 \"__EMIT_PATH__\" ended 2>/dev/null || true" } ] }
    ]
  }
}
